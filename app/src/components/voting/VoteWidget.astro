---
interface Props {
  targetType: 'principle' | 'value';
  targetId: string;
  className?: string;
}
const { targetType, targetId, className = '' } = Astro.props;
---
<div class={`vote-widget ${className}`} data-vote-target-type={targetType} data-vote-target-id={targetId}>
  <button type="button" class="vote-btn vote-up" aria-label="Agree" data-vote-action="up">
    <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
      <path d="M8 3.5l4 4.5h-2.5v4.5h-3V8H4l4-4.5z" fill="currentColor"/>
    </svg>
  </button>
  <span class="vote-score" data-vote-score>0</span>
  <button type="button" class="vote-btn vote-down" aria-label="Disagree" data-vote-action="down">
    <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
      <path d="M8 12.5l-4-4.5h2.5V3.5h3V8H12l-4 4.5z" fill="currentColor"/>
    </svg>
  </button>
</div>

<style>
.vote-widget {
  display: inline-flex;
  align-items: stretch;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.04em;
  border: 1px solid var(--rule);
  border-radius: 999px;
  background: var(--paper);
  overflow: hidden;
  isolation: isolate;
  box-shadow: 0 1px 0 0 oklch(from var(--paper) calc(l + 0.04) c h) inset;
  transition: border-color .2s, box-shadow .2s;
}
.vote-widget:hover {
  border-color: oklch(from var(--accent) l c h / 0.55);
  box-shadow:
    0 1px 0 0 oklch(from var(--paper) calc(l + 0.04) c h) inset,
    0 6px 16px -8px oklch(0.18 0.012 60 / 0.18);
}
.vote-btn {
  background: none;
  border: none;
  cursor: pointer;
  width: 30px; height: 30px;
  display: inline-flex; align-items: center; justify-content: center;
  color: var(--ink-3);
  position: relative;
  transition: color .15s, background .15s, transform .12s;
}
.vote-btn svg { width: 14px; height: 14px; transition: transform .2s cubic-bezier(.2,.7,.2,1); }
.vote-btn:hover { color: var(--ink); }
.vote-btn:active { transform: scale(0.92); }
.vote-btn:focus-visible { outline: none; box-shadow: 0 0 0 2px var(--accent-soft) inset; }
.vote-up:hover { color: oklch(0.50 0.16 145); background: oklch(0.50 0.16 145 / 0.10); }
.vote-up:hover svg { transform: translateY(-2px); }
.vote-down:hover { color: oklch(0.55 0.18 25); background: oklch(0.55 0.18 25 / 0.10); }
.vote-down:hover svg { transform: translateY(2px); }
.vote-up.is-cast { color: oklch(0.50 0.16 145); }
.vote-down.is-cast { color: oklch(0.55 0.18 25); }
.vote-score {
  min-width: 2.4ch;
  padding: 0 4px;
  display: inline-flex; align-items: center; justify-content: center;
  font-family: var(--serif);
  font-variation-settings: "opsz" 144, "wght" 380;
  font-style: italic;
  font-size: 14px;
  letter-spacing: -0.01em;
  color: var(--ink);
  border-left: 1px solid var(--rule);
  border-right: 1px solid var(--rule);
  background: var(--paper-2);
  font-variant-numeric: tabular-nums;
}
.vote-score[data-vote-score]:not([data-vote-score="0"]) { color: var(--accent); }
</style>

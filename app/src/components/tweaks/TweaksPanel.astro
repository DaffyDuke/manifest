---
const SWATCHES = [
  { hue: 275, label: 'Blue' },
  { hue: 245, label: 'Indigo' },
  { hue: 162, label: 'Mint' },
  { hue: 9,   label: 'Rose' },
  { hue: 60,  label: 'Amber' },
];
---
<div id="tweaks" role="region" aria-label="Theme tweaks">
  <h4>Tweaks</h4>
  <div class="row">
    <span id="tweak-accent-label">Accent</span>
    <div class="swatches" id="swatches" aria-labelledby="tweak-accent-label">
      {SWATCHES.map(s => (
        <button
          class="swatch"
          type="button"
          aria-pressed={s.hue === 275 ? 'true' : 'false'}
          aria-label={`Accent ${s.label}`}
          data-hue={s.hue}
          style={`background: oklch(0.54 0.246 ${s.hue})`}
        />
      ))}
    </div>
  </div>
  <div class="row">
    <label for="paperSel">Paper</label>
    <select id="paperSel">
      <option value="ice">Ice</option>
      <option value="warm">Warm</option>
      <option value="slate">Slate</option>
    </select>
  </div>
  <div class="row">
    <label for="serifScale">Type size</label>
    <input type="range" id="serifScale" min="0.9" max="1.15" step="0.01" aria-label="Type size scale" />
  </div>
  <div class="row">
    <label for="rainbowToggle">Rainbow principles</label>
    <input type="checkbox" id="rainbowToggle" />
  </div>
</div>

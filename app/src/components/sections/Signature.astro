---
import SignatureWall from '~/components/signature/SignatureWall.astro';
import { SEEDS } from '~/content/seeds';
const initialCount = SEEDS.length;
---
<section id="sign" class="signature">
  <div class="sig-head">
    <h3>Sign the manifesto.</h3>
    <p>If this reflects how you already work — or how you want to — claim it. One click via LinkedIn. You join the ones who build with intention.</p>
  </div>

  <div class="sig-count" aria-live="polite">
    <span class="num" data-signature-count>{initialCount}</span>
    <span class="label">signed</span>
  </div>

  <SignatureWall />

  <div class="sig-foot">
    <button class="print-btn" id="printBtn" type="button">⎙ Print as broadside</button>
  </div>
</section>

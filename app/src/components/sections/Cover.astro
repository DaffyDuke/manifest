---
// Cover — typographic monument. Asymmetric grid, oversized title, real
// publication marks at the four edges, ghosted Fraunces watermark behind.
---
<section class="cover" data-screen-label="Cover">
  <div class="cover-watermark" aria-hidden="true">M</div>

  <div class="cover-rule cover-rule-top" aria-hidden="true"></div>
  <div class="cover-rule cover-rule-bottom" aria-hidden="true"></div>

  <div class="cover-folio cover-folio-tl">
    <span class="folio-num">N<span class="folio-dot">o</span> 01·0001</span>
    <span class="folio-pub">A Living Document</span>
  </div>
  <div class="cover-folio cover-folio-tr">
    <span class="folio-pub">v1.0 · Open Edition</span>
    <span class="folio-num"><span class="folio-pulse"></span>2026</span>
  </div>
  <div class="cover-folio cover-folio-bl">
    <span class="folio-pub">For the post-keystroke author</span>
  </div>
  <div class="cover-folio cover-folio-br">
    <span class="folio-pub">File under <em>practice</em></span>
  </div>

  <h1 class="cover-title">
    <span class="line line-1"><span class="word reveal-word" style="--d:.05s">The</span> <span class="word reveal-word" style="--d:.18s">Manifesto</span></span>
    <span class="line line-2"><span class="word for reveal-word" style="--d:.32s">for</span></span>
    <span class="line line-3"><span class="word ai reveal-word" style="--d:.45s">
      <span class="ai-text">AI-Driven</span>
      <span class="ai-strike" aria-hidden="true"></span>
    </span></span>
    <span class="line line-4"><span class="word reveal-word" style="--d:.62s">Development.</span></span>
  </h1>

  <div class="cover-colophon" aria-hidden="true">
    <span class="col-mark">·</span>
    <span>Free to read</span>
    <span class="col-mark">·</span>
    <span>Free to sign</span>
    <span class="col-mark">·</span>
    <span>Free to fork</span>
    <span class="col-mark">·</span>
  </div>
</section>

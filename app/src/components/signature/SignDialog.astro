---
// Sign-in dialog. Visually framed as a LinkedIn SSO step.
// Real OAuth (LinkedIn OpenID Connect) is wired server-side in /api/auth/linkedin
// (TODO: see app/src/pages/api/signatures.ts comment block). For now we
// capture name + LinkedIn URL with required validation; the form posts to /api/signatures.
---
<dialog id="signDialog" class="sign-dialog">
  <form method="dialog" id="signDialogForm" class="sign-form" novalidate>
    <div class="sd-brand">
      <svg class="sd-li" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="currentColor" d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.13 1 2.5 1s2.48 1.12 2.48 2.5zM.22 8h4.56v14H.22V8zm7.66 0h4.37v1.92h.06c.61-1.16 2.1-2.38 4.32-2.38 4.62 0 5.47 3.04 5.47 7v8.46h-4.55v-7.5c0-1.79-.03-4.09-2.49-4.09-2.5 0-2.88 1.95-2.88 3.96V22H7.88V8z"/>
      </svg>
      <span class="sd-kicker">LinkedIn · Sign-in</span>
    </div>
    <h4>Claim your signature.</h4>
    <p class="sd-lede">One identity. Public, verifiable, and yours. Your name and profile URL — nothing else.</p>

    <label class="sd-field">
      <span>Full name</span>
      <input type="text" id="dialogSignName" placeholder="Ada Lovelace" maxlength="60" required autocomplete="name" />
    </label>
    <label class="sd-field">
      <span>LinkedIn profile</span>
      <input type="url" id="dialogSignLinkedin" placeholder="https://www.linkedin.com/in/your-handle" maxlength="200" required pattern="https://([a-z]{2,3}\.)?linkedin\.com/.*" />
      <small class="sd-hint">Required — proves the signature is really yours.</small>
    </label>

    <div class="dialog-actions">
      <button type="button" class="dialog-cancel" data-close>Cancel</button>
      <button type="submit" class="sign-action">
        <svg class="sd-li sd-li-sm" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.13 1 2.5 1s2.48 1.12 2.48 2.5zM.22 8h4.56v14H.22V8zm7.66 0h4.37v1.92h.06c.61-1.16 2.1-2.38 4.32-2.38 4.62 0 5.47 3.04 5.47 7v8.46h-4.55v-7.5c0-1.79-.03-4.09-2.49-4.09-2.5 0-2.88 1.95-2.88 3.96V22H7.88V8z"/>
        </svg>
        Sign with LinkedIn
      </button>
    </div>
    <small class="sd-foot">By signing, you agree the manifesto reflects how you want to build. Free to fork, free to leave.</small>
  </form>
</dialog>
<style>
.sign-dialog {
  border: none;
  padding: 0;
  border-radius: 14px;
  background: var(--paper);
  color: var(--ink);
  max-width: 460px;
  width: 92vw;
  box-shadow:
    0 1px 0 0 oklch(from var(--paper) calc(l + 0.04) c h) inset,
    0 30px 80px -20px oklch(0.18 0.012 60 / 0.45);
  overflow: hidden;
}
.sign-dialog::backdrop {
  background: oklch(0.18 0.012 60 / 0.55);
  backdrop-filter: blur(6px);
}
.sign-dialog .sign-form {
  display: grid; gap: 14px;
  padding: 28px 28px 22px;
}
.sd-brand { display: inline-flex; align-items: center; gap: 10px; }
.sd-li {
  width: 24px; height: 24px;
  padding: 4px; border-radius: 4px;
  background: oklch(0.32 0.10 250);
  color: oklch(0.97 0.01 240);
  flex: none;
}
.sd-li-sm { width: 16px; height: 16px; padding: 2px; border-radius: 3px; }
.sd-kicker {
  font-family: var(--mono);
  font-size: 10.5px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink-3);
}
.sign-dialog h4 {
  font-family: var(--serif);
  font-variation-settings: "opsz" 144, "wght" 360;
  font-style: italic;
  font-size: 28px;
  line-height: 1.05;
  margin: 4px 0 0;
  color: var(--ink);
}
.sd-lede {
  font-family: var(--sans);
  font-size: 13.5px;
  line-height: 1.55;
  color: var(--ink-2);
  margin: 0 0 4px;
  max-width: 38ch;
}
.sd-field { display: grid; gap: 6px; }
.sd-field > span {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink-3);
}
.sd-field input {
  font-family: var(--sans);
  font-size: 14px;
  padding: 12px 14px;
  border: 1px solid var(--rule);
  background: var(--paper-2);
  color: var(--ink);
  border-radius: 6px;
  transition: border-color .2s, box-shadow .2s;
  outline: none;
}
.sd-field input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-soft);
}
.sd-field input:invalid:not(:placeholder-shown) {
  border-color: oklch(0.55 0.18 25);
}
.sd-hint {
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--ink-3);
}
.dialog-actions {
  display: flex; gap: 10px; justify-content: flex-end; margin-top: 6px;
}
.dialog-cancel {
  background: none;
  border: 1px solid var(--rule);
  padding: 11px 16px;
  cursor: pointer;
  font-family: var(--mono);
  font-size: 10.5px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-2);
  border-radius: 6px;
  transition: border-color .2s, color .2s;
}
.dialog-cancel:hover { border-color: var(--ink); color: var(--ink); }
.sign-dialog .sign-action {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 11px 18px;
  border: none; cursor: pointer;
  border-radius: 6px;
  background: linear-gradient(135deg, oklch(0.32 0.10 250), oklch(0.22 0.05 250));
  color: oklch(0.97 0.01 240);
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  box-shadow: 0 8px 24px -8px oklch(0.22 0.05 250 / 0.55);
  transition: transform .2s, filter .2s;
}
.sign-dialog .sign-action:hover { filter: brightness(1.08); transform: translateY(-1px); }
.sd-foot {
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-3);
  margin-top: 4px;
  line-height: 1.6;
}
</style>

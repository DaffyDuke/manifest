---
// Floating header + floating "Sign with LinkedIn" CTA, both fixed.
---
<header class="floating-header" data-floating-header>
  <a class="fh-mark" href="#top" aria-label="AI-Driven Development">
    <img src="/brand/aidd-logo.svg" alt="" width="28" height="28" />
    <span class="fh-mark-text">AI-Driven<br/>Development</span>
  </a>
  <nav class="fh-nav">
    <a href="#preamble">Preamble</a>
    <a href="#values">Values</a>
    <a href="#principles">Principles</a>
    <a href="#sign">Signatories</a>
  </nav>
  <div class="fh-meta"><span class="dot"></span>v1.0 · Living</div>
</header>

<button type="button" class="floating-sign" id="signOpen" data-floating-sign>
  <svg class="fs-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <path fill="currentColor" d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.13 1 2.5 1s2.48 1.12 2.48 2.5zM.22 8h4.56v14H.22V8zm7.66 0h4.37v1.92h.06c.61-1.16 2.1-2.38 4.32-2.38 4.62 0 5.47 3.04 5.47 7v8.46h-4.55v-7.5c0-1.79-.03-4.09-2.49-4.09-2.5 0-2.88 1.95-2.88 3.96V22H7.88V8z"/>
  </svg>
  <span class="fs-label">Sign with LinkedIn</span>
  <span class="fs-count" data-signature-count>0</span>
</button>

<style>
.floating-header {
  position: fixed;
  top: 18px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 90;
  display: flex; align-items: center; gap: clamp(18px, 3vw, 36px);
  padding: 10px 14px 10px 12px;
  background: oklch(from var(--paper) l c h / 0.78);
  -webkit-backdrop-filter: blur(14px) saturate(140%);
          backdrop-filter: blur(14px) saturate(140%);
  border: 1px solid var(--rule);
  border-radius: 999px;
  box-shadow:
    0 1px 0 0 oklch(from var(--paper) calc(l + 0.04) c h / 0.6) inset,
    0 10px 32px -16px oklch(0.18 0.012 60 / 0.18);
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-2);
  max-width: calc(100vw - 32px);
  opacity: 0;
  transform: translate(-50%, -8px);
  transition: opacity .35s ease, transform .35s cubic-bezier(.2,.7,.2,1);
  pointer-events: none;
}
.floating-header.is-on { opacity: 1; transform: translate(-50%, 0); pointer-events: auto; }
.fh-mark {
  display: inline-flex; align-items: center; gap: 10px;
  text-decoration: none; color: var(--ink);
  padding: 4px 12px 4px 4px;
  border-right: 1px solid var(--rule);
}
.fh-mark img { display: block; border-radius: 50%; }
.fh-mark-text {
  font-family: var(--serif);
  font-style: italic;
  font-variation-settings: "opsz" 144, "wght" 360;
  font-size: 12px;
  letter-spacing: -0.01em;
  text-transform: none;
  line-height: 1;
  color: var(--ink);
}
.fh-nav { display: flex; gap: clamp(14px, 2vw, 26px); }
.fh-nav a {
  color: var(--ink-3);
  text-decoration: none;
  position: relative;
  padding-bottom: 2px;
  transition: color .2s;
}
.fh-nav a::after{
  content:""; position:absolute; left:0; right:0; bottom:-2px;
  height: 1px; background: var(--accent);
  transform: scaleX(0); transform-origin: left;
  transition: transform .25s cubic-bezier(.2,.7,.2,1);
}
.fh-nav a:hover{ color: var(--ink); }
.fh-nav a:hover::after{ transform: scaleX(1); }
.fh-meta { display: inline-flex; align-items: center; gap: 8px; color: var(--ink-3); padding-left: clamp(6px, 1vw, 14px); border-left: 1px solid var(--rule); }
.fh-meta .dot {
  width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
  animation: fh-pulse 2.4s ease-in-out infinite;
}
@keyframes fh-pulse { 0%,100%{opacity:.5; transform:scale(1)} 50%{opacity:1; transform:scale(1.3)} }

@media (max-width: 760px) {
  .fh-nav, .fh-meta { display: none; }
  .floating-header { padding: 8px 14px 8px 6px; }
}

/* ============ Floating sign button ============ */
.floating-sign {
  position: fixed;
  right: clamp(16px, 3vw, 32px);
  bottom: clamp(16px, 3vw, 32px);
  z-index: 95;
  display: inline-flex; align-items: center; gap: 12px;
  padding: 14px 22px 14px 18px;
  border: none; cursor: pointer;
  border-radius: 999px;
  background: linear-gradient(135deg, oklch(0.32 0.10 250), oklch(0.22 0.05 250));
  color: oklch(0.97 0.01 240);
  font-family: var(--mono);
  font-size: 11.5px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  box-shadow:
    0 1px 0 0 oklch(0.55 0.10 250 / 0.45) inset,
    0 0 0 1px oklch(0.97 0.01 240 / 0.06) inset,
    0 18px 40px -12px oklch(0.22 0.05 250 / 0.55),
    0 4px 10px -2px oklch(0.18 0.012 60 / 0.25);
  transition: transform .25s cubic-bezier(.2,.7,.2,1), box-shadow .25s, filter .25s;
  opacity: 0;
  transform: translateY(20px) scale(0.96);
  pointer-events: none;
}
.floating-sign.is-on {
  opacity: 1;
  transform: translateY(0) scale(1);
  pointer-events: auto;
}
.floating-sign:hover {
  transform: translateY(-2px) scale(1.02);
  filter: brightness(1.08);
}
.floating-sign:active { transform: translateY(0) scale(0.99); }
.floating-sign:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
.fs-icon {
  width: 18px; height: 18px;
  padding: 4px;
  border-radius: 4px;
  background: oklch(0.97 0.01 240);
  color: oklch(0.32 0.10 250);
  flex: none;
}
.fs-label { font-weight: 500; }
.fs-count {
  font-family: var(--serif);
  font-variation-settings: "opsz" 144, "wght" 380;
  font-style: italic;
  font-size: 18px;
  letter-spacing: -0.01em;
  text-transform: none;
  padding: 0 6px;
  border-left: 1px solid oklch(0.97 0.01 240 / 0.25);
  margin-left: 4px;
  color: oklch(0.97 0.01 240);
  font-variant-numeric: tabular-nums;
}

@media (max-width: 480px) {
  .floating-sign { padding: 12px 16px; gap: 10px; }
  .fs-label { display: none; }
  .floating-sign::after {
    content: "Sign";
    font-family: var(--mono);
    font-size: 11.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
}

@media print {
  .floating-header, .floating-sign { display: none !important; }
}
</style>

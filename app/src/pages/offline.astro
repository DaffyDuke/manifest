---
import Page from '~/components/layout/Page.astro';

const description = 'Offline fallback for the AI-Driven Development manifesto site.';
---
<Page title="Offline" description={description} path="/offline" noindex>
  <main class="plain-page" id="main">
    <div class="plain-page-inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Offline</span>
      </nav>
      <h1>Offline</h1>
      <p>
        The network is unavailable. If this page was cached by your browser, the manifesto
        should return when the connection is back.
      </p>
      <a class="action-link" href="/">Retry the manifesto</a>
    </div>
  </main>
</Page>
